#!/bin/sh
# WB Starter Pre-commit Hook
# Runs project-integrity tests before allowing commit

echo "🏷  Stamping version..."
node scripts/stamp-version.js
git add src/core/version.js

echo "🔍 Running pre-commit checks..."

# Run project integrity tests
npm test -- --grep "project-integrity" --reporter=line

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Pre-commit checks FAILED"
  echo "   Fix the issues above before committing."
  echo ""
  exit 1
fi

echo ""
echo "✅ Pre-commit checks passed"
echo ""
