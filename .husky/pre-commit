#!/bin/sh
# WB Starter Pre-commit Hook
# Runs project-integrity tests before allowing commit

echo "🏷  Stamping version..."
node scripts/stamp-version.js
# stamp-version.js also bumps every ?v= cache-busting query string in
# index.html/project-index.html to match — only version.js was ever
# re-staged, leaving those two perpetually one commit stale (each commit's
# stamp reflected the PARENT commit's hash, since HEAD hasn't moved yet
# when this hook runs, and the cache-bust for THIS commit's own changes
# never got included in it).
git add src/core/version.js index.html project-index.html

echo "🔍 Running pre-commit checks..."

# Run project integrity tests only — NOT `npm test` (the full multi-tier
# matrix: compliance/regression/integration/base/behaviors, ~1hr). `npm test
# -- --grep ...` only appends those flags to the LAST command in that
# &&-chained script, so every commit was silently running the ENTIRE suite
# unfiltered before this fix (never caught: core.hooksPath wasn't set for
# this worktree until now, so the hook itself had never actually run).
npx playwright test tests/compliance/project-integrity.spec.ts --reporter=line

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Pre-commit checks FAILED"
  echo "   Fix the issues above before committing."
  echo ""
  exit 1
fi

echo ""
echo "✅ Pre-commit checks passed"
echo ""
