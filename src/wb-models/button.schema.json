{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "button.schema.json",
  "title": "Button",
  "description": "Interactive button with variants, sizes, and optional icon",
  "schemaFor": "button",
  "baseClass": "wb-button",
  "semanticElement": {
    "tagName": "button",
    "implicitRole": "button"
  },
  "compliance": {
    "baseClass": "wb-button",
    "supportLevel": "stable",
    "accessibility": "high"
  },
  "properties": {
    "label": {
      "type": "string",
      "description": "Button text",
      "default": ""
    },
    "icon": {
      "type": "string",
      "description": "Icon name from built-in library, or any emoji/text",
      "enum": [
        "",
        "star",
        "check",
        "close",
        "warning",
        "info",
        "error",
        "heart",
        "search",
        "edit",
        "trash",
        "plus",
        "minus",
        "home",
        "settings",
        "download",
        "upload",
        "arrow_right",
        "arrow_left",
        "copy",
        "save"
      ],
      "default": ""
    },
    "iconPosition": {
      "type": "string",
      "description": "Icon position relative to label",
      "enum": [
        "start",
        "end"
      ],
      "default": "start"
    },
    "variant": {
      "type": "string",
      "description": "Visual style variant",
      "enum": [
        "primary",
        "secondary",
        "success",
        "warning",
        "error",
        "ghost",
        "outline",
        "link"
      ],
      "default": "primary",
      "appliesClass": "wb-button--{{value}}"
    },
    "size": {
      "type": "string",
      "description": "Button size",
      "enum": [
        "xs",
        "sm",
        "md",
        "lg",
        "xl"
      ],
      "default": "md",
      "appliesClass": "wb-button--{{value}}"
    },
    "disabled": {
      "type": "boolean",
      "description": "Disabled state",
      "default": false
    },
    "loading": {
      "type": "boolean",
      "description": "Loading state with spinner",
      "default": false,
      "appliesClass": "wb-button--loading"
    },
    "fullWidth": {
      "type": "boolean",
      "description": "Full width button",
      "default": false,
      "appliesClass": "wb-button--full"
    },
    "iconOnly": {
      "type": "boolean",
      "description": "Icon-only button (square)",
      "default": false,
      "appliesClass": "wb-button--icon-only"
    }
  },
  "_view_note": "The button BEHAVIOR (src/wb-viewmodels/semantics/button.js) is the SOLE renderer of <wb-button> — its own comment: 'CSS targets the tag and attributes directly. No inner <button> created. No classes added.' This $view rebuilt content via buildStructure() (element.innerHTML = '' then rebuild from $view/slot) whenever schema processing reached a <wb-button> — including ones created and populated by OTHER behaviors at runtime (e.g. feedback.js's alert() dismiss button, plain textContent = '×'), silently replacing that content with a span-wrapped version and contributing to the alert dismiss-button bug (see alert.schema.json). Emptied, same fix already applied to 'card' (#202) and 'alert'.",
  "$view": [],
  "$methods": {
    "enable": {
      "description": "Enables the button",
      "params": []
    },
    "disable": {
      "description": "Disables the button",
      "params": []
    },
    "startLoading": {
      "description": "Shows loading state",
      "params": []
    },
    "stopLoading": {
      "description": "Hides loading state",
      "params": []
    },
    "click": {
      "description": "Programmatically clicks the button",
      "params": []
    },
    "focus": {
      "description": "Focuses the button",
      "params": []
    },
    "blur": {
      "description": "Removes focus from button",
      "params": []
    }
  },
  "$cssAPI": {
    "--wb-button-padding-x": {
      "default": "1rem",
      "description": "Horizontal padding"
    },
    "--wb-button-padding-y": {
      "default": "0.5rem",
      "description": "Vertical padding"
    },
    "--wb-button-radius": {
      "default": "4px",
      "description": "Border radius"
    },
    "--wb-button-font-size": {
      "default": "0.875rem",
      "description": "Font size"
    },
    "--wb-button-font-weight": {
      "default": "600",
      "description": "Font weight"
    },
    "--wb-button-gap": {
      "default": "0.5rem",
      "description": "Gap between icon and label"
    },
    "--wb-button-transition": {
      "default": "all 0.15s ease",
      "description": "Transition for hover/active states"
    },
    "--wb-button-primary-bg": {
      "default": "var(--primary, #6366f1)",
      "description": "Primary variant background"
    },
    "--wb-button-primary-color": {
      "default": "#ffffff",
      "description": "Primary variant text color"
    },
    "--wb-button-primary-hover-bg": {
      "default": "var(--primary-dark, #4f46e5)",
      "description": "Primary variant hover background"
    },
    "--wb-button-secondary-bg": {
      "default": "var(--secondary, #64748b)",
      "description": "Secondary variant background"
    },
    "--wb-button-secondary-color": {
      "default": "#ffffff",
      "description": "Secondary variant text color"
    },
    "--wb-button-success-bg": {
      "default": "var(--success, #4caf50)",
      "description": "Success variant background"
    },
    "--wb-button-success-color": {
      "default": "#ffffff",
      "description": "Success variant text color"
    },
    "--wb-button-warning-bg": {
      "default": "var(--warning, #ff9800)",
      "description": "Warning variant background"
    },
    "--wb-button-warning-color": {
      "default": "#ffffff",
      "description": "Warning variant text color"
    },
    "--wb-button-error-bg": {
      "default": "var(--error, #f44336)",
      "description": "Error variant background"
    },
    "--wb-button-error-color": {
      "default": "#ffffff",
      "description": "Error variant text color"
    },
    "--wb-button-ghost-bg": {
      "default": "transparent",
      "description": "Ghost variant background"
    },
    "--wb-button-ghost-color": {
      "default": "var(--text-primary, #1a1a1a)",
      "description": "Ghost variant text color"
    },
    "--wb-button-ghost-hover-bg": {
      "default": "var(--bg-hover, rgba(0,0,0,0.05))",
      "description": "Ghost variant hover background"
    },
    "--wb-button-outline-border": {
      "default": "1px solid currentColor",
      "description": "Outline variant border"
    },
    "--wb-button-disabled-opacity": {
      "default": "0.5",
      "description": "Disabled state opacity"
    },
    "--wb-button-focus-ring": {
      "default": "0 0 0 3px rgba(99, 102, 241, 0.3)",
      "description": "Focus ring box-shadow"
    }
  },
  "accessibility": {
    "role": "button",
    "ariaDisabled": "dynamic when disabled"
  },
  "interactions": {
    "elements": {
      "element": {
        "type": "button",
        "click": {
          "action": "triggers click handler",
          "event": "wb:button:click"
        }
      }
    }
  },
  "test": {
    "setup": [
      "<wb-button>Basic button content</wb-button>",
      "<wb-button icon-position=\"start\">iconPosition=start</wb-button>",
      "<wb-button icon-position=\"end\">iconPosition=end</wb-button>",
      "<wb-button variant=\"primary\">variant=primary</wb-button>",
      "<wb-button variant=\"secondary\">variant=secondary</wb-button>",
      "<wb-button variant=\"success\">variant=success</wb-button>",
      "<wb-button size=\"xs\">size=xs</wb-button>",
      "<wb-button size=\"sm\">size=sm</wb-button>"
    ],
    "functional": {
      "buttons": [
        {
          "name": "Basic Click",
          "setup": "<wb-button>Click Me</wb-button>",
          "selector": "element",
          "expect": {
            "textContains": "Click Me",
            "event": "click"
          }
        },
        {
          "name": "Variant Classes",
          "setup": "<wb-button variant='primary'>Primary</wb-button>",
          "selector": "element",
          "expect": {
            "hasClass": "wb-button--primary"
          }
        }
      ],
      "focus": [
        {
          "name": "Focus State",
          "setup": "<wb-button>Focus Me</wb-button>",
          "action": "click",
          "selector": "element",
          "expect": {
            "focused": true
          }
        }
      ],
      "disabled": [
        {
          "name": "Disabled State",
          "setup": "<wb-button disabled>Disabled</wb-button>",
          "action": "click",
          "selector": "element",
          "expect": {
            "event": null,
            "attribute": {
              "disabled": ""
            }
          }
        }
      ],
      "keyboard": [
        {
          "name": "Enter Key",
          "setup": "<wb-button>Enter Me</wb-button>",
          "key": "Enter",
          "expect": {
            "event": "click"
          }
        },
        {
          "name": "Space Key",
          "setup": "<wb-button>Space Me</wb-button>",
          "key": "Space",
          "expect": {
            "event": "click"
          }
        }
      ]
    },
    "matrix": {
      "combinations": [
        {
          "label": "Primary",
          "variant": "primary"
        },
        {
          "label": "Secondary",
          "variant": "secondary"
        },
        {
          "label": "Success",
          "variant": "success"
        },
        {
          "label": "Warning",
          "variant": "warning"
        },
        {
          "label": "Error",
          "variant": "error"
        },
        {
          "label": "Ghost",
          "variant": "ghost"
        },
        {
          "label": "Outline",
          "variant": "outline"
        },
        {
          "label": "Small",
          "variant": "primary",
          "size": "sm"
        },
        {
          "label": "Large",
          "variant": "primary",
          "size": "lg"
        },
        {
          "label": "Loading...",
          "variant": "primary",
          "loading": true
        },
        {
          "label": "🚀 With Icon",
          "variant": "primary",
          "icon": "🚀"
        }
      ]
    },
    "site": {
      "page": "forms",
      "tag": "wb-button",
      "renders": true,
      "baseClass": "wb-button",
      "minInstances": 11,
      "checkText": [
        "Primary",
        "Secondary",
        "Success",
        "Warning"
      ],
      "checkClasses": [
        "wb-button--secondary",
        "wb-button--xs"
      ],
      "checkAttributes": [
        "label",
        "variant"
      ]
    }
  },
  "_metadata": {
    "category": "forms",
    "icon": "🔘",
    "since": "1.0.0",
    "status": "stable"
  }
}
