      "manualSections": [
        {
          "heading": "🎬 Semantic Media Elements",
          "id": "semantic-media-elements",
          "html": "<p>Enhanced media elements using standard HTML tags.</p>\r\n\r\n  <!-- AUDIO -->\r\n  <h2>Audio <code>&lt;audio&gt;</code></h2>\r\n  <div class=\"demo-section\">\r\n    <p>Standard Player</p>\r\n    <wb-demo>\r\n      <audio id=\"semanticsmedia-audio-20\" controls src=\"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3\"></audio>\r\n    </wb-demo>\r\n\r\n    <p>Studio EQ Player — with 15-band graphic equalizer</p>\r\n    <wb-demo>\r\n      <wb-audio\r\n        src=\"https://files.freemusicarchive.org/storage-freemusicarchive-org/music/no_curator/Tours/Enthusiast/Tours_-_01_-_Enthusiast.mp3\"\r\n        show-eq\r\n        volume=\"0.7\"\r\n        playlist=\"https://files.freemusicarchive.org/storage-freemusicarchive-org/music/no_curator/Tours/Enthusiast/Tours_-_01_-_Enthusiast.mp3|Tours - Enthusiast,https://archive.org/download/nineinchnails_ghosts_I_IV/01_Ghosts_I.mp3|Ghosts I - Track 1,https://archive.org/download/nineinchnails_ghosts_I_IV/02_Ghosts_I.mp3|Ghosts I - Track 2,https://archive.org/download/nineinchnails_ghosts_I_IV/03_Ghosts_I.mp3|Ghosts I - Track 3,https://archive.org/download/nineinchnails_ghosts_I_IV/04_Ghosts_I.mp3|Ghosts I - Track 4,https://archive.org/download/nineinchnails_ghosts_I_IV/05_Ghosts_I.mp3|Ghosts I - Track 5,https://archive.org/download/nineinchnails_ghosts_I_IV/06_Ghosts_I.mp3|Ghosts I - Track 6,https://archive.org/download/nineinchnails_ghosts_I_IV/07_Ghosts_I.mp3|Ghosts I - Track 7,https://archive.org/download/nineinchnails_ghosts_I_IV/08_Ghosts_I.mp3|Ghosts I - Track 8,https://archive.org/download/nineinchnails_ghosts_I_IV/09_Ghosts_I.mp3|Ghosts I - Track 9,https://archive.org/download/nineinchnails_ghosts_I_IV/10_Ghosts_II.mp3|Ghosts II - Track 1,https://archive.org/download/nineinchnails_ghosts_I_IV/11_Ghosts_II.mp3|Ghosts II - Track 2,https://archive.org/download/nineinchnails_ghosts_I_IV/12_Ghosts_II.mp3|Ghosts II - Track 3,https://archive.org/download/nineinchnails_ghosts_I_IV/13_Ghosts_II.mp3|Ghosts II - Track 4,https://archive.org/download/nineinchnails_ghosts_I_IV/14_Ghosts_II.mp3|Ghosts II - Track 5,https://archive.org/download/nineinchnails_ghosts_I_IV/15_Ghosts_II.mp3|Ghosts II - Track 6,https://archive.org/download/nineinchnails_ghosts_I_IV/16_Ghosts_II.mp3|Ghosts II - Track 7,https://archive.org/download/nineinchnails_ghosts_I_IV/17_Ghosts_II.mp3|Ghosts II - Track 8\">\r\n      </wb-audio>\r\n    </wb-demo>\r\n  </div>\r\n\r\n  <!-- VIDEO -->\r\n  <h2>Video <code>&lt;video&gt;</code></h2>\r\n  <div class=\"demo-section\">\r\n    <p>Standard Video</p>\r\n    <wb-demo>\r\n      <video controls src=\"https://www.w3schools.com/html/mov_bbb.mp4\" style=\"width: 100%; border-radius: 8px;\"></video>\r\n    </wb-demo>\r\n\r\n    <p>Background Video (Muted Loop)</p>\r\n    <wb-demo>\r\n      <video\r\n        src=\"https://www.w3schools.com/html/movie.mp4\"\r\n        autoplay\r\n        muted\r\n        loop\r\n        style=\"width: 100%; border-radius: 8px; opacity: 0.6;\">\r\n      </video>\r\n    </wb-demo>\r\n  </div>\r\n\r\n  <!-- IMAGE -->\r\n  <h2>Image <code>&lt;img&gt;</code></h2>\r\n  <div class=\"demo-section\">\r\n    <p>Zoomable Image (Lightbox)</p>\r\n    <wb-demo>\r\n      <img src=\"https://picsum.photos/id/1018/800/600\" zoomable alt=\"Nature Scene\" style=\"width: 100%; border-radius: 8px;\">\r\n    </wb-demo>\r\n\r\n    <p>Lazy Loaded with Aspect Ratio</p>\r\n    <wb-demo>\r\n      <img src=\"https://picsum.photos/id/1015/800/600\" lazy aspect-ratio=\"4/3\" alt=\"River\" style=\"width: 100%; border-radius: 8px;\">\r\n    </wb-demo>\r\n  </div>\r\n\r\n  <!-- FIGURE -->\r\n  <h2>Figure <code>&lt;figure&gt;</code></h2>\r\n  <div class=\"demo-section\">\r\n    <p>Standard Figure</p>\r\n    <wb-demo>\r\n      <figure zoom>\r\n        <img src=\"https://picsum.photos/id/1016/800/600\" alt=\"Canyon\" style=\"width: 100%;\">\r\n        <figcaption>A beautiful canyon view</figcaption>\r\n      </figure>\r\n    </wb-demo>\r\n\r\n    <p>Overlay Caption</p>\r\n    <wb-demo>\r\n      <figure caption-position=\"overlay\" lightbox>\r\n        <img src=\"https://picsum.photos/id/1019/800/600\" alt=\"Technology\" style=\"width: 100%;\">\r\n        <figcaption>Technology and Nature</figcaption>\r\n      </figure>\r\n    </wb-demo>\r\n  </div>"
        },
        {
          "heading": "🏗️ Semantic Structure Elements",
          "id": "semantic-structure-elements",
          "html": "<p>Enhanced structural and data elements using standard HTML tags.</p>\n\n  <!-- TABLE -->\n  <h2>Table <code>&lt;table&gt;</code></h2>\n  <p>Features: sortable columns (click header), copyable cells (click cell), searchable, striped rows.</p>\n  <div class=\"demo-section\">\n    <wb-demo columns=\"1\">\n      <table sortable searchable striped hover copyable>\n        <thead>\n          <tr><th>ID</th><th>Name</th><th>Role</th><th>Status</th></tr>\n        </thead>\n        <tbody>\n          <tr><td>1</td><td>Alice Smith</td><td>Developer</td><td>Active</td></tr>\n          <tr><td>2</td><td>Bob Jones</td><td>Designer</td><td>Active</td></tr>\n          <tr><td>3</td><td>Charlie Brown</td><td>Manager</td><td>Away</td></tr>\n        </tbody>\n      </table>\n    </wb-demo>\n  </div>\n\n  <!-- DETAILS -->\n  <h2>Details <code>&lt;details&gt;</code></h2>\n  <div class=\"demo-section\">\n    <wb-demo columns=\"3\">\n      <details>\n        <summary>Detail Item 1</summary>\n        <p>This is the content for item 1.</p>\n      </details>\n      <details open>\n        <summary>Detail Item 2 (open by default)</summary>\n        <p>This is the content for item 2.</p>\n      </details>\n      <details animated=\"false\">\n        <summary>Detail Item 3 (no animation)</summary>\n        <p>This is the content for item 3.</p>\n      </details>\n    </wb-demo>\n  </div>\n\n  <!-- DIALOG -->\n  <h2>Dialog <code>&lt;dialog&gt;</code></h2>\n  <div class=\"demo-section\">\n    <p>Native <code>&lt;dialog&gt;</code> shown via <code>showModal()</code> — hidden by default, so it isn't itself a <code>&lt;wb-demo&gt;</code> candidate (nothing to render inline); the trigger button is.</p>\n    <wb-demo columns=\"1\">\n      <button id=\"open-dialog-btn\">Open Modal Dialog</button>\n    </wb-demo>\n    <div id=\"padding-warning\" class=\"padding-warning\">\n      ⚠️ Modal blocked: Body requires at least 1rem padding on left and right sides.\n    </div>\n    <dialog id=\"demo-dialog\">\n      <form method=\"dialog\">\n        <h3>Confirmation</h3>\n        <p>This is a native dialog.</p>\n        <div style=\"display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;\">\n          <button value=\"cancel\">Cancel</button>\n          <button value=\"confirm\" autofocus>Confirm</button>\n        </div>\n      </form>\n    </dialog>\n  </div>\n\n  <!-- PROGRESS -->\n  <h2>Progress <code>&lt;wb-progress&gt;</code></h2>\n  <div class=\"demo-section\">\n    <wb-demo columns=\"2\">\n      <wb-progress value=\"70\" label=\"Loading...\"></wb-progress>\n      <wb-progress indeterminate label=\"Working...\"></wb-progress>\n    </wb-demo>\n  </div>\n\n  <!-- CODE & PRE -->\n  <h2>Code <code>&lt;code&gt;</code> &amp; <code>&lt;pre&gt;</code></h2>\n  <div class=\"demo-section\">\n    <p>Inline Code</p>\n    <wb-demo columns=\"1\">\n      <p>Use <code>console.log()</code> to install.</p>\n    </wb-demo>\n\n    <p>Code Block</p>\n    <wb-demo columns=\"1\">\n      <pre x-behavior=\"pre\" show-copy show-line-numbers language=\"javascript\"><code>function hello() {\n  console.log(\"Hello World\");\n  return true;\n}</code></pre>\n    </wb-demo>\n  </div>\n\n  <!-- LISTS -->\n  <h2>Lists <code>&lt;ul&gt;, &lt;ol&gt;, &lt;dl&gt;</code></h2>\n  <div class=\"demo-section\">\n    <wb-demo columns=\"3\">\n      <ul>\n        <li>Feature One</li>\n        <li>Feature Two</li>\n        <li>Feature Three</li>\n      </ul>\n      <ol>\n        <li>Step One</li>\n        <li>Step Two</li>\n        <li>Step Three</li>\n      </ol>\n      <dl>\n        <dt>HTML</dt>\n        <dd>HyperText Markup Language</dd>\n        <dt>CSS</dt>\n        <dd>Cascading Style Sheets</dd>\n      </dl>\n    </wb-demo>\n  </div>\n\n  <!-- TEXT-LEVEL SEMANTICS -->\n  <h2>Text-Level Semantics</h2>\n  <div class=\"demo-section\">\n    <wb-demo columns=\"4\">\n      <blockquote>\"Web functionality.\" <cite>— Author</cite></blockquote>\n      <address>123 Street, Anytown</address>\n      <p>Deprecated: <del>old price</del> New: <ins>new price</ins></p>\n      <abbr title=\"HyperText Markup Language\">HTML</abbr>\n      <p>Meeting at <time datetime=\"2026-07-12T09:00\">9am, July 12</time></p>\n      <p>x<sup>2</sup> + y<sup>2</sup> = z<sup>2</sup></p>\n      <p>H<sub>2</sub>O</p>\n      <hr>\n    </wb-demo>\n  </div>\n\n  <!-- LINK -->\n  <h2>Link <code>.wb-link</code></h2>\n  <div class=\"demo-section\">\n    <wb-demo columns=\"1\">\n      <a href=\"#\" class=\"wb-link\">Styled Link</a>\n    </wb-demo>\n  </div>",
          "script": "// Modal padding validation\n    const openDialogBtn = document.getElementById('open-dialog-btn');\n    const demoDialog = document.getElementById('demo-dialog');\n    const paddingWarning = document.getElementById('padding-warning');\n\n    function hasRequiredPadding() {\n      const bodyStyle = window.getComputedStyle(document.body);\n      const paddingLeft = parseFloat(bodyStyle.paddingLeft);\n      const paddingRight = parseFloat(bodyStyle.paddingRight);\n      return paddingLeft >= 16 && paddingRight >= 16;\n    }\n\n    openDialogBtn.addEventListener('click', () => {\n      if (hasRequiredPadding()) {\n        paddingWarning.classList.remove('show');\n        demoDialog.showModal();\n      } else {\n        paddingWarning.classList.add('show');\n        console.warn('Modal blocked: Body requires at least 1rem padding on left and right sides.');\n      }\n    });"
        }
      ]
    },
    {
